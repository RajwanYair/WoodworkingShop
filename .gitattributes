# .gitattributes — Ensure consistent line endings and binary handling

# Default: auto-detect
* text=auto

# Force LF for all text source files
*.py text eol=lf
*.md text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Binary files
*.pdf binary
*.svg binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
