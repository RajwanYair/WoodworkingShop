# .gitattributes — Ensure consistent line endings and binary handling

# Default: auto-detect
* text=auto

# Force LF for all text source files
*.py text eol=lf
*.md text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.svg text eol=lf

# Windows script files — CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ttf binary
*.woff binary
*.woff2 binary
