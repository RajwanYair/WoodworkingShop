{
    "name": "woodworkingshop",
    "version": "2.6.0",
    "description": "Interactive cabinet planner — configure, preview, and download PDF build plans",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ --max-warnings 0 .",
        "typecheck": "tsc -b --noEmit",
        "check": "npm run typecheck && npm run lint && npm run test",
        "ci": "npm run check && npm run build"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@react-pdf/renderer": "^4.0.0",
        "i18next": "^25.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-i18next": "^15.0.0",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "~5.8.0",
        "vite": "^6.0.0"
    }
}
